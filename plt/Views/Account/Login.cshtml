@using movieRecom.Models.ViewModel
@model LoginViewModel
@{
    ViewData["Title"] = "Вход";
}
<div class="register-container">
    <form asp-action="Login" method="post" class="form-card">
        <h2 class="form-title">Вход</h2>


        <div class="form-group">
            <label asp-for="Email">Email</label>
            <input asp-for="Email" class="form-control" type="email" required />
        </div>

        <div class="form-group">
            <label asp-for="Password">Пароль</label>
            <input asp-for="Password" class="form-control" type="password" required />
        </div>


        <div class="form-group">
            <button type="submit" class="btn-register">Войти</button>
        </div>

        <div class="form-footer">
            <p>Нет аккаунта? <a asp-action="Register" class="link-accent">Зарегистрироваться</a></p>
        </div>
    </form>
</div>

<style>
    .register-container {
        min-height: calc(100vh - 200px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
    }

    .form-card {
        background: linear-gradient(145deg, #1a1a2e 0%, #16213e 100%);
        padding: 3rem;
        border-radius: 20px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.5);
        width: 100%;
        max-width: 450px;
    }

    .form-title {
        font-size: 2rem;
        margin-bottom: 2rem;
        text-align: center;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .form-group label {
        display: block;
        margin-bottom: 0.5rem;
        color: #ccc;
        font-weight: 500;
    }

    .form-control {
        width: 100%;
        padding: 0.9rem 1.2rem;
        border: 2px solid #3a3a5c;
        border-radius: 10px;
        background: #0f0f23;
        color: #fff;
        font-size: 1rem;
        transition: all 0.3s ease;
    }

    .form-control:focus {
        outline: none;
        border-color: #667eea;
        box-shadow: 0 0 20px rgba(102, 126, 234, 0.4);
    }

    .btn-register {
        width: 100%;
        padding: 1rem;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        border-radius: 10px;
        color: #fff;
        font-size: 1.1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .btn-register:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 30px rgba(102, 126, 234, 0.5);
    }

    .form-footer {
        margin-top: 2rem;
        text-align: center;
        padding-top: 1.5rem;
        border-top: 1px solid #3a3a5c;
    }

    .form-footer p {
        color: #888;
        margin: 0;
    }

    .link-accent {
        color: #667eea;
        text-decoration: none;
        font-weight: 600;
        transition: color 0.3s ease;
    }

    .link-accent:hover {
        color: #764ba2;
        text-decoration: underline;
    }
</style>
