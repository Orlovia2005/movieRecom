@section Scripts {
<script src="~/js/Profile.js"></script>
}
@model plt.Models.ViewModel.ProfileViewModel
@{
    ViewData["Title"] = "Профиль";
}

<div class="profile-container">
    <!-- Левое меню -->
    <aside class="profile-sidebar">
        <ul>
            <li class="active" data-tab="general">Общие данные</li>
            <li data-tab="password">Смена пароля</li>
            <form asp-action="Logout" asp-controller="Account" enctype="multipart/form-data">
                <button type="submit" class="btn btn_logaut">Выйти</button>
            </form>

        </ul>
    </aside>

    <!-- Контент -->
    <section class="profile-content">
        <!-- Общие данные -->
        <div class="tab-content active" id="general">
            <h2>Общие данные</h2>

            <form asp-action="UpdateProfile" asp-controller="Account" method="post" enctype="multipart/form-data">
                <!-- скрытый ID -->
                <input type="hidden" asp-for="Id" />

                <!-- Аватар -->
                <div class="form-group">
                    <div class="avatar-wrapper">
                        @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                        {
                            <img src="@Model.AvatarUrl" alt="Аватар" class="avatar-preview" id="avatarPreview" />
                        }
                        else
                        {
                            <img src="~/Images/BaseAvatar.jpg" alt="Аватар" class="avatar-preview" id="avatarPreview" />
                        }
                    </div>

                    <!-- input для выбора файла -->
                    <input type="file" id="avatarInput" name="avatar" accept="image/*" hidden />
                    <button type="button" class="btn btn-accent" id="chooseAvatarBtn">Выбрать файл</button>
                    <span id="fileName" class="file-name">Файл не выбран</span>
                </div>

                <!-- Имя -->
                <div class="form-group">
                    <label asp-for="FirstName">Имя</label>
                    <input type="text" class="form-control" asp-for="FirstName" />
                </div>

                <!-- Фамилия -->
                <div class="form-group">
                    <label asp-for="SecondName">Фамилия</label>
                    <input type="text" class="form-control" asp-for="SecondName" />
                </div>

                <!-- Email -->
                <div class="form-group">
                    <label asp-for="Email">Email</label>
                    <input type="email" class="form-control" asp-for="Email" />
                </div>

                <button type="submit" class="btn btn-accent">Сохранить</button>
            </form>
            
        </div>

        <!-- Пароль -->
        <div class="tab-content" id="password">
            <h2>Смена пароля</h2>

            <form asp-action="UpdatePassword" asp-controller="Account" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="form-group">
                    <label asp-for="OldPassword">Старый пароль</label>
                    <input type="password" class="form-control" asp-for="OldPassword" />
                </div>

                <div class="form-group">
                    <label asp-for="NewPassword">Новый пароль</label>
                    <input type="password" class="form-control" asp-for="NewPassword" />
                </div>

                <div class="form-group">
                    <label asp-for="ConfirmNewPassword">Повторите пароль</label>
                    <input type="password" class="form-control" asp-for="ConfirmNewPassword" />
                </div>

                <button type="submit" class="btn btn-accent">Обновить пароль</button>
            </form>
        </div>
    </section>
</div>
