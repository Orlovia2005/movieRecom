@using movieRecom.Models.Model
@model Movie
@{
    ViewData["Title"] = "Редактировать фильм";
    var genres = ViewBag.Genres as List<Genre> ?? new List<Genre>();
    var selectedGenres = ViewBag.SelectedGenres as List<int> ?? new List<int>();
}

<div class="container py-4">
    <h1 class="mb-4"><i class="bi bi-pencil"></i> Редактировать: @Model.Title</h1>

    <form asp-action="EditMovie" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="row">
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label">Название *</label>
                    <input asp-for="Title" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Описание</label>
                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">Год выпуска</label>
                            <input asp-for="ReleaseYear" type="number" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">Продолжительность (мин)</label>
                            <input asp-for="Runtime" type="number" class="form-control" />
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label">IMDB ID</label>
                    <input asp-for="ImdbId" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label">IMDB Рейтинг</label>
                    <input asp-for="ImdbRating" type="number" step="0.1" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label">URL постера</label>
                    <input asp-for="PosterUrl" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Жанры</label>
                    <div class="border rounded p-2" style="max-height: 200px; overflow-y: auto;">
                        @foreach (var genre in genres)
                        {
                            <div class="form-check">
                                <input type="checkbox" name="selectedGenres" value="@genre.Id"
                                       class="form-check-input" id="genre_@genre.Id"
                                       @(selectedGenres.Contains(genre.Id) ? "checked" : "")>
                                <label class="form-check-label" for="genre_@genre.Id">@genre.Name</label>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
        <div class="mt-3">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-save"></i> Сохранить изменения
            </button>
            <a asp-action="Movies" class="btn btn-secondary">Отмена</a>
        </div>
    </form>
</div>
