@using movieRecom.Controllers
@model List<UserAdminViewModel>
@{
    ViewData["Title"] = "Пользователи";
}

<div class="container py-4">
    <h1 class="mb-4"><i class="bi bi-people"></i> Пользователи</h1>

    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Имя</th>
                <th>Email</th>
                <th>Роль</th>
                <th>Оценок</th>
                <th>В списке желаний</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.Id</td>
                    <td>@user.Name @user.LastName</td>
                    <td>@user.Email</td>
                    <td>
                        @if (user.Role == movieRecom.Models.Model.UserRole.Admin)
                        {
                            <span class="badge bg-danger">Администратор</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Пользователь</span>
                        }
                    </td>
                    <td>@user.RatingsCount</td>
                    <td>@user.WishlistCount</td>
                    <td>
                        <form asp-action="ChangeRole" method="post" class="d-inline">
                            <input type="hidden" name="userId" value="@user.Id" />
                            @if (user.Role == movieRecom.Models.Model.UserRole.Admin)
                            {
                                <input type="hidden" name="role" value="User" />
                                <button type="submit" class="btn btn-sm btn-outline-warning" title="Сделать пользователем">
                                    <i class="bi bi-person"></i>
                                </button>
                            }
                            else
                            {
                                <input type="hidden" name="role" value="Admin" />
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Сделать администратором">
                                    <i class="bi bi-shield"></i>
                                </button>
                            }
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Назад
    </a>
</div>
