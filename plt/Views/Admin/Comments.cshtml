@using movieRecom.Models.Model
@model List<Comment>
@{
    ViewData["Title"] = "Модерация комментариев";
    bool showPending = ViewBag.ShowPending ?? true;
}

<div class="container py-4">
    <h1 class="mb-4"><i class="bi bi-chat-left-text"></i> Модерация комментариев</h1>

    <ul class="nav nav-tabs mb-4">
        <li class="nav-item">
            <a class="nav-link @(showPending ? "active" : "")" asp-action="Comments" asp-route-pending="true">
                Ожидают модерации
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(!showPending ? "active" : "")" asp-action="Comments" asp-route-pending="false">
                Одобренные
            </a>
        </li>
    </ul>

    @if (Model.Any())
    {
        <div class="list-group">
            @foreach (var comment in Model)
            {
                <div class="list-group-item">
                    <div class="d-flex justify-content-between align-items-start">
                        <div class="flex-grow-1">
                            <h6 class="mb-1">
                                <strong>@comment.User.Name @comment.User.LastName</strong>
                                <small class="text-muted">о фильме "@comment.Movie.Title"</small>
                            </h6>
                            <p class="mb-1">@comment.Text</p>
                            <small class="text-muted">@comment.CreatedAt.ToString("dd.MM.yyyy HH:mm")</small>
                        </div>
                        <div class="btn-group btn-group-sm ms-3">
                            @if (!comment.IsApproved)
                            {
                                <form asp-action="ApproveComment" asp-route-id="@comment.Id" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-success" title="Одобрить">
                                        <i class="bi bi-check-lg"></i>
                                    </button>
                                </form>
                            }
                            <form asp-action="DeleteComment" asp-route-id="@comment.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Удалить комментарий?');">
                                <button type="submit" class="btn btn-danger" title="Удалить">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info">
            @(showPending ? "Нет комментариев, ожидающих модерации" : "Нет одобренных комментариев")
        </div>
    }

    <a asp-action="Index" class="btn btn-secondary mt-3">
        <i class="bi bi-arrow-left"></i> Назад
    </a>
</div>
