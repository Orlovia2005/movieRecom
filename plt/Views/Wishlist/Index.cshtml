@using movieRecom.Models.Model
@model List<Wishlist>
@{
    ViewData["Title"] = "Мой список желаний";
}

<div class="container py-4">
    <h1 class="mb-4">
        <i class="bi bi-heart-fill text-danger"></i> Мой список желаний
    </h1>

    @if (Model.Any())
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 shadow-sm">
                        @if (!string.IsNullOrEmpty(item.Movie.PosterUrl))
                        {
                            <img src="@item.Movie.PosterUrl" class="card-img-top" alt="@item.Movie.Title" 
                                 style="height: 300px; object-fit: cover;">
                        }
                        else
                        {
                            <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center" 
                                 style="height: 300px;">
                                <i class="bi bi-film text-white" style="font-size: 4rem;"></i>
                            </div>
                        }
                        <div class="card-body">
                            <h5 class="card-title">@item.Movie.Title</h5>
                            <p class="card-text text-muted">
                                @if (item.Movie.ReleaseYear.HasValue)
                                {
                                    <span>@item.Movie.ReleaseYear</span>
                                }
                                @if (item.Movie.ImdbRating.HasValue)
                                {
                                    <span class="ms-2">
                                        <i class="bi bi-star-fill text-warning"></i> @item.Movie.ImdbRating
                                    </span>
                                }
                            </p>
                            <p class="text-muted small">
                                Добавлено: @item.AddedAt.ToString("dd.MM.yyyy")
                            </p>
                            <div class="d-flex gap-2">
                                <a asp-controller="Movies" asp-action="Details" asp-route-id="@item.Movie.Id" 
                                   class="btn btn-primary flex-grow-1">
                                    Подробнее
                                </a>
                                <form asp-action="Remove" method="post">
                                    <input type="hidden" name="movieId" value="@item.Movie.Id" />
                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                    <button type="submit" class="btn btn-outline-danger" title="Удалить">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-heart text-muted" style="font-size: 4rem;"></i>
            <h3 class="mt-3">Ваш список желаний пуст</h3>
            <p class="text-muted">Добавляйте фильмы, чтобы не забыть их посмотреть</p>
            <a asp-controller="Movies" asp-action="Index" class="btn btn-primary mt-2">
                Перейти к каталогу
            </a>
        </div>
    }
</div>
