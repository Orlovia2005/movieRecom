
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - MyApp</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <div class="toast-container">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="toast toast-success">
                <span>@TempData["SuccessMessage"]</span>
                <button class="btn-close">&times;</button>
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="toast toast-error">
                <span>@TempData["ErrorMessage"]</span>
                <button class="btn-close">&times;</button>
            </div>
        }

        @if (TempData["InfoMessage"] != null)
        {
            <div class="toast toast-info">
                <span>@TempData["InfoMessage"]</span>
                <button class="btn-close">&times;</button>
            </div>
        }
    </div>


    <header class="site-header">
        <div class="container header-container">
            <div class="logo">
                <a href="/">MovieRecom</a>
            </div>
            <nav class="nav-menu">
                <a asp-controller="Home" asp-action="Index">Главная</a>
                

            </nav>
            <div class="auth-buttons">
                <div class="auth-buttons">
                    @if (User.Identity.IsAuthenticated)
                    {
                        var avatarUrl = User.FindFirst("avatar_url")?.Value ?? Url.Content("~/Images/BaseAvatar.jpg");


                        <div class="profile-menu">
                            <a asp-controller="Account" asp-action="Profile" class="avatar-link">
                                <img src="@avatarUrl" alt="Аватар" class="avatar-preview" id="avatarPreview" />
                            </a>
                        </div>
                    }
                    else
                    {
                        <a class="btn" asp-controller="Account" asp-action="Login">Вход</a>
                        <a class="btn btn-accent" asp-controller="Account" asp-action="Register">Регистрация</a>
                    }
                </div>

            </div>

        </div>
    </header>

    <main class="container body-content">
        @RenderBody()
    </main>
    @RenderSection("Scripts", required: false)
</body>
</html>
<script>
        document.addEventListener("DOMContentLoaded", () => {
        const toasts = document.querySelectorAll('.toast');

        toasts.forEach(toast => {
            toast.classList.add('show');

            setTimeout(() => {
                toast.classList.remove('show');
                setTimeout(() => toast.remove(), 400);
            }, 4000);

            const btnClose = toast.querySelector('.btn-close');
            if (btnClose) {
                btnClose.addEventListener('click', () => {
                    toast.classList.remove('show');
                    setTimeout(() => toast.remove(), 400);
                });
            }
        });
    });

</script>


